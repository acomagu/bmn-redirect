{
  "name": "Shared URL Viewer",
  "short_name": "URL Viewer",
  "start_url": "./",
  "display": "standalone",
  "share_target": {
    "action": "./",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "url": "url",
      "title": "title",
      "text": "text"
    }
  }
}
